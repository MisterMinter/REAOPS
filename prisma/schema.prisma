generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth (Auth.js) ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-tenancy ───────────────────────────────────────────

model Tenant {
  id            String  @id @default(cuid())
  name          String
  slug          String  @unique
  logoUrl       String?
  brokerageName String?
  isActive      Boolean @default(true)

  hubspotTokens HubSpotTokens?
  bufferTokens  BufferTokens?
  driveConfig   DriveConfig?

  hubspotListingObject String @default("deals")
  hubspotListingProps  Json?

  defaultTone          String @default("Warm but professional. First-name basis. No pressure.")
  complianceStandard   String @default("ga_residential")
  brokerPhone          String?
  flyerNotifyEmail     String?
  defaultApprovalMode  ApprovalMode @default(AUTO_SEND_LOW_RISK)

  users                 User[]
  activityLogs          ActivityLog[]
  cachedListings        CachedListing[]
  cachedContacts        CachedContact[]
  zillowProfileSources  ZillowProfileSource[]
  leadSources           LeadSource[]
  pipelines             Pipeline[]
  contacts              Contact[]
  listings              Listing[]
  opportunities         Opportunity[]
  touchpoints           Touchpoint[]
  followUpTasks         FollowUpTask[]
  messageDrafts         MessageDraft[]
  approvals             Approval[]
  automationRules       AutomationRule[]
  channelAccounts       ChannelAccount[]
  sendingIdentities     SendingIdentity[]
  marketingAssets       MarketingAsset[]
  complianceReviews     ComplianceReview[]
  sopTemplates          SopTemplate[]
  integrationMappings   IntegrationMapping[]
  syncRuns              SyncRun[]
  auditEvents           AuditEvent[]
  agentLoops            AgentLoop[]
  agentRuns             AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Broker/agent Zillow profile or team URLs to import active listing zpids (best-effort HTML parse).
model ZillowProfileSource {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileUrl     String    @db.Text
  displayLabel   String?
  assignedUserId String?
  assignedUser   User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  lastSyncedAt   DateTime?
  lastSyncError  String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
}

model HubSpotTokens {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessToken String   @db.Text
  refreshToken String  @db.Text
  expiresAt   DateTime
  hubId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BufferTokens {
  id           String    @id @default(cuid())
  tenantId     String    @unique
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  profileIds   Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model DriveConfig {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rootFolderId  String
  folderMapping Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Users & Roles ───────────────────────────────────────────

enum UserRole {
  ADMIN
  BROKER_OWNER
  AGENT
}

enum FollowUpTaskStatus {
  OPEN
  DRAFTED
  WAITING_APPROVAL
  APPROVED
  SENT
  SKIPPED
  FAILED
}

enum MessageRisk {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalMode {
  DRAFT_ONLY
  APPROVAL_REQUIRED
  AUTO_SEND_LOW_RISK
  AUTO_SEND_ALL
}

enum ChannelKind {
  GMAIL
  TELEGRAM
  BLUEBUBBLES
  WHATSAPP
  SMS
}

enum SendingIdentityType {
  SHARED_OPS
  BROKER_OWNER
  ASSIGNED_AGENT
}

enum TouchpointDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum MessageDraftStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  SENT
  SKIPPED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MarketingAssetType {
  FLYER
  SOCIAL_IMAGE
  SOCIAL_COPY
  EMAIL_COPY
  MLS_COPY
}

enum MarketingAssetStatus {
  DRAFT
  GENERATED
  APPROVED
  PUBLISHED
  FAILED
}

enum ComplianceReviewStatus {
  OPEN
  IN_REVIEW
  FLAGGED
  CLEARED
  NEEDS_HUMAN
}

enum SyncRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum AgentLoopKind {
  DAILY_OPS
  FOLLOW_UP_RECOVERY
  MARKETING_PLANNING
  COMPLIANCE_SWEEP
}

enum AgentRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  name     String?
  image    String?
  emailVerified DateTime?

  role   UserRole @default(AGENT)
  tenantId String?
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])

  telegramId       String?   @unique
  assignedListings Json?
  lastLoginAt      DateTime?
  isActive         Boolean   @default(true)

  accounts      Account[]
  sessions      Session[]
  activityLogs           ActivityLog[]
  chatSessions           ChatSession[]
  zillowProfileSources   ZillowProfileSource[]
  ownedContacts          Contact[]        @relation("ContactOwner")
  ownedTasks             FollowUpTask[]   @relation("FollowUpTaskOwner")
  createdTasks           FollowUpTask[]   @relation("FollowUpTaskCreator")
  createdDrafts          MessageDraft[]   @relation("MessageDraftCreator")
  approvalsRequested     Approval[]       @relation("ApprovalRequester")
  approvalsDecided       Approval[]       @relation("ApprovalDecider")
  touchpointsCreated     Touchpoint[]     @relation("TouchpointCreator")
  sendingIdentities      SendingIdentity[]
  auditEvents            AuditEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model LeadSource {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  isActive  Boolean  @default(true)
  contacts  Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Pipeline {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  isDefault Boolean         @default(false)
  stages    PipelineStage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model PipelineStage {
  id            String        @id @default(cuid())
  pipelineId    String
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  position      Int           @default(0)
  isClosed      Boolean       @default(false)
  contacts      Contact[]
  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pipelineId, slug])
  @@index([pipelineId, position])
}

model Contact {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerUserId     String?
  owner           User?          @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  leadSourceId    String?
  leadSource      LeadSource?    @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  externalId      String?
  sourceSystem    String?
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  status          String         @default("New")
  isVip           Boolean        @default(false)
  lastContactAt   DateTime?
  nextActionAt    DateTime?
  notes           String?        @db.Text
  rawData         Json?

  opportunities     Opportunity[]
  touchpoints       Touchpoint[]
  followUpTasks     FollowUpTask[]
  messageDrafts     MessageDraft[]
  marketingAssets   MarketingAsset[]
  complianceReviews ComplianceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

model Listing {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  externalId    String?
  sourceSystem  String?
  address       String
  shortAddress  String
  city          String?
  state         String?
  zip           String?
  beds          Int?
  baths         Float?
  sqft          Int?
  price         Int?
  priceDisplay  String?
  status        String   @default("Active")
  daysOnMarket  Int?
  features      String?  @db.Text
  notes         String?  @db.Text
  mlsNumber     String?
  driveFolderId String?
  rawData       Json?

  opportunities     Opportunity[]
  touchpoints       Touchpoint[]
  followUpTasks     FollowUpTask[]
  marketingAssets   MarketingAsset[]
  complianceReviews ComplianceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, externalId])
  @@index([tenantId, mlsNumber])
  @@unique([tenantId, sourceSystem, externalId])
}

model Opportunity {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  listingId       String?
  listing         Listing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)
  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  externalId      String?
  sourceSystem    String?
  title           String
  type            String         @default("buyer")
  status          String         @default("Open")
  value           Int?
  rawData         Json?

  touchpoints       Touchpoint[]
  followUpTasks     FollowUpTask[]
  complianceReviews ComplianceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, listingId])
}

model Touchpoint {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  listingId      String?
  listing        Listing?            @relation(fields: [listingId], references: [id], onDelete: SetNull)
  opportunityId  String?
  opportunity    Opportunity?        @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  followUpTaskId String?
  followUpTask   FollowUpTask?       @relation(fields: [followUpTaskId], references: [id], onDelete: SetNull)
  messageDraftId String?
  messageDraft   MessageDraft?       @relation(fields: [messageDraftId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       User?              @relation("TouchpointCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  channel        ChannelKind?
  direction      TouchpointDirection @default(INTERNAL)
  subject        String?
  body           String              @db.Text
  externalId     String?
  occurredAt     DateTime            @default(now())
  metadata       Json?

  createdAt DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, contactId])
  @@index([tenantId, followUpTaskId])
}

model FollowUpTask {
  id               String             @id @default(cuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  listingId        String?
  listing          Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?       @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  ownerUserId      String?
  owner            User?              @relation("FollowUpTaskOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUserId  String?
  createdBy        User?              @relation("FollowUpTaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  automationRuleId String?
  automationRule   AutomationRule?    @relation(fields: [automationRuleId], references: [id], onDelete: SetNull)
  title            String
  context          String?            @db.Text
  source           String             @default("manual")
  status           FollowUpTaskStatus @default(OPEN)
  risk             MessageRisk        @default(LOW)
  priority         Int                @default(3)
  dueAt            DateTime?
  completedAt      DateTime?
  lastError        String?            @db.Text

  drafts      MessageDraft[]
  approvals   Approval[]
  touchpoints Touchpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, contactId])
}

model MessageDraft {
  id                String             @id @default(cuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  taskId            String?
  task              FollowUpTask?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  contactId         String?
  contact           Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  sendingIdentityId String?
  sendingIdentity   SendingIdentity?   @relation(fields: [sendingIdentityId], references: [id], onDelete: SetNull)
  createdByUserId   String?
  createdBy         User?              @relation("MessageDraftCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  channel           ChannelKind
  risk              MessageRisk        @default(LOW)
  status            MessageDraftStatus @default(DRAFT)
  subject           String?
  body              String             @db.Text
  recipient         String?
  requiresApproval  Boolean            @default(true)
  approvedAt        DateTime?
  sentAt            DateTime?
  externalMessageId String?
  metadata          Json?

  approvals   Approval[]
  touchpoints Touchpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, taskId])
}

model Approval {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  draftId         String?
  draft           MessageDraft?  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  taskId          String?
  task            FollowUpTask?  @relation(fields: [taskId], references: [id], onDelete: SetNull)
  requestedForId  String?
  requestedFor    User?          @relation("ApprovalRequester", fields: [requestedForId], references: [id], onDelete: SetNull)
  decidedById     String?
  decidedBy       User?          @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  status          ApprovalStatus @default(PENDING)
  reason          String?        @db.Text
  decidedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, draftId])
}

model AutomationRule {
  id                  String              @id @default(cuid())
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  trigger             String
  channel             ChannelKind         @default(GMAIL)
  approvalMode        ApprovalMode        @default(AUTO_SEND_LOW_RISK)
  sendingIdentityType SendingIdentityType @default(SHARED_OPS)
  enabled             Boolean             @default(true)
  conditions          Json?
  template            Json?

  followUpTasks FollowUpTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, enabled])
}

model ChannelAccount {
  id                String      @id @default(cuid())
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind              ChannelKind
  label             String
  status            String      @default("configured")
  config            Json?
  secretRef         String?
  lastHealthCheckAt DateTime?
  lastError         String?     @db.Text

  sendingIdentities SendingIdentity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, kind])
}

model SendingIdentity {
  id               String              @id @default(cuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channelAccountId String?
  channelAccount   ChannelAccount?     @relation(fields: [channelAccountId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  type             SendingIdentityType @default(SHARED_OPS)
  channel          ChannelKind         @default(GMAIL)
  displayName      String
  email            String?
  phone            String?
  externalRef      String?
  isDefault        Boolean             @default(false)

  messageDrafts MessageDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, channel])
  @@index([tenantId, isDefault])
}

model MarketingAsset {
  id              String               @id @default(cuid())
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId       String?
  listing         Listing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)
  contactId       String?
  contact         Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdByUserId String?
  type            MarketingAssetType
  status          MarketingAssetStatus @default(DRAFT)
  title           String
  content         String?              @db.Text
  driveFileId     String?
  publicUrl       String?
  metadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, listingId])
}

model SopTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  category  String   @default("contract")
  body      String   @db.Text
  checklist Json?
  isDefault Boolean  @default(false)

  complianceReviews ComplianceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, category])
}

model ComplianceReview {
  id              String                 @id @default(cuid())
  tenantId        String
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  listingId       String?
  listing         Listing?               @relation(fields: [listingId], references: [id], onDelete: SetNull)
  opportunityId   String?
  opportunity     Opportunity?           @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  sopTemplateId   String?
  sopTemplate     SopTemplate?           @relation(fields: [sopTemplateId], references: [id], onDelete: SetNull)
  status          ComplianceReviewStatus @default(OPEN)
  title           String
  summary         String?                @db.Text
  flags           Json?
  deadlineAt      DateTime?
  reviewedById    String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, deadlineAt])
}

model IntegrationMapping {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     String
  objectType   String
  fieldMapping Json
  enabled      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, provider, objectType])
}

model SyncRun {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider   String
  direction  String        @default("inbound")
  status     SyncRunStatus @default(PENDING)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  summary    Json?
  error      String?       @db.Text

  createdAt DateTime @default(now())

  @@index([tenantId, provider, startedAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  subjectType String?
  subjectId   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, subjectType, subjectId])
}

model AgentLoop {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      AgentLoopKind
  name      String
  enabled   Boolean       @default(true)
  cadence   String        @default("manual")
  persona   String?
  config    Json?
  lastRunAt DateTime?
  runs      AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, kind])
  @@index([tenantId, enabled])
}

model AgentRun {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loopId      String?
  loop        AgentLoop?     @relation(fields: [loopId], references: [id], onDelete: SetNull)
  kind        AgentLoopKind
  status      AgentRunStatus @default(RUNNING)
  trigger     String         @default("manual")
  summary     String?        @db.Text
  observations Json?
  actions     Json?
  error       String?        @db.Text
  startedAt   DateTime       @default(now())
  finishedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, startedAt])
  @@index([tenantId, kind])
  @@index([tenantId, status])
}

model CachedListing {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hubspotId     String
  address       String
  shortAddress  String
  city          String
  state         String
  zip           String?
  beds          Int?
  baths         Float?
  sqft          Int?
  price         Int?
  priceDisplay  String
  status        String
  daysOnMarket  Int?
  features      String?
  notes         String?
  mlsNumber     String?
  driveFolderId String?
  rawData       Json
  lastSyncedAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, hubspotId])
  @@index([tenantId])
}

model CachedContact {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hubspotId       String
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  leadStatus      String?
  lastContactDate DateTime?
  associatedDeals Json?
  notes           String?
  rawData         Json
  lastSyncedAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, hubspotId])
  @@index([tenantId])
}

model ChatSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel        String   @default("web")
  externalChatId String?
  messages       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([userId, channel, externalChatId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
