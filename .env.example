# App
NODE_ENV=development
# Production: https://reaops.com
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Drive listing photos use the signed-in user's token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (Railway or local)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Encrypt stored integration tokens (32-byte key, base64)
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# HubSpot (tenant OAuth later; app credentials if using a single app)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Buffer (optional, V1+)
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=

# Broker assistant (set at least one; server-side only)
# Priority: AI_PROVIDER=gemini,anthropic,openai (comma-separated)
AI_PROVIDER=gemini,anthropic,openai
GEMINI_API_KEY=
# Optional overrides (defaults: gemini-2.0-flash, claude-sonnet-4-6, gpt-4o-mini)
# GEMINI_MODEL=
# ANTHROPIC_MODEL=
# OPENAI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
