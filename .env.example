# App
NODE_ENV=development
# Production: https://reaops.com
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Drive listing photos use the signed-in user's token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (Railway or local)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Encrypt stored integration tokens (32-byte key, base64)
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# HubSpot tenant OAuth app credentials
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
# Optional override; defaults to NEXTAUTH_URL + /api/hubspot/callback
HUBSPOT_REDIRECT_URI=
# Optional override; default required scopes cover contacts and deals/listings
HUBSPOT_SCOPES=
# Optional override; defaults to notes write so REAOPS touchpoints can appear on HubSpot timelines
HUBSPOT_OPTIONAL_SCOPES=
# Optional pagination guard; 10 pages = up to 1,000 records per object per manual sync
HUBSPOT_SYNC_MAX_PAGES=10

# Buffer (optional, V1+)
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=

# Broker assistant (set at least one; server-side only)
# Priority: AI_PROVIDER=anthropic,gemini,openai (comma-separated)
AI_PROVIDER=anthropic,gemini,openai
GEMINI_API_KEY=
# Optional overrides (defaults: gemini-2.0-flash, claude-sonnet-4-6, gpt-4o-mini)
# GEMINI_MODEL=
# ANTHROPIC_MODEL=
# OPENAI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Firecrawl (proxy-based web scraping for Zillow — https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Cron/job endpoint auth (required in production)
# openssl rand -hex 32
CRON_SECRET=

# Tenant brain / GBrain (optional; app degrades to Prisma-only context when unset)
GBRAIN_BASE_URL=
GBRAIN_API_KEY=
# Optional path overrides for a shared GBrain HTTP gateway
# GBRAIN_INGEST_PATH=/api/memory/ingest
# GBRAIN_QUERY_PATH=/api/memory/query
# GBRAIN_DECISION_PATH=/api/memory/decisions
# GBRAIN_HEALTH_PATH=/health
# GBRAIN_TIMEOUT_MS=3500

# Zillow sync endpoint auth (optional — protects /api/zillow/sync from external calls)
# openssl rand -hex 32
ZILLOW_SYNC_SECRET=

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Random string for webhook verification: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Buffer (Phase 2)
BUFFER_ACCESS_TOKEN=
