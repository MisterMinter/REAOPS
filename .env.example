# App
NODE_ENV=development
# Production: https://reaops.com
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (same GCP project as service account)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (Railway or local)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Encrypt stored integration tokens (32-byte key, base64)
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Optional: tenant logos on Google Cloud Storage (recommended on Railway)
GCS_BUCKET_LOGOS=
# e.g. https://storage.googleapis.com/your-bucket or your CDN base (no trailing slash)
GCS_PUBLIC_BASE_URL=
# Service account with objectAdmin on the logo bucket (same GCP project as OAuth is fine)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# PEM private key; use \n for newlines in Railway one-line env
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# HubSpot (tenant OAuth later; app credentials if using a single app)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Buffer (optional, V1+)
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=

# Anthropic (broker assistant)
ANTHROPIC_API_KEY=
